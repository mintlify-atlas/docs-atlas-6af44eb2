  "keyFeatures": [
    "Modular component system (add/remove at any time)",
    "CLI-driven project scaffolding with Copier templates",
    "Built-in system visibility via Overseer dashboard",
    "FastAPI backend with async Python support",
    "Docker-based development workflow",
    "Background job processing with workers and scheduler",
    "Optional AI service with PydanticAI/LangChain",
    "Authentication service with JWT",
    "Communications service (email/SMS)",
    "Live CLI interface for system inspection",
    "Template versioning and update management"
  ],
